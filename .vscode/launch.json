            "args": [
                "--video_folder",
                "datasets/ropedia/ep1",
                "--save_visualization",
                "--valid_iters", "32",
                "--conf_threshold", "0.5",
                "--baseline", "0.12831688"
            ]
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
